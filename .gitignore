# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
qweb

# Test binary, built with `go test -c`
*.test

# Output of the go build
*.out

# Go workspace file
go.work
go.work.sum

# Dependency directories
node_modules
web/test-results
vendor/

# IDE specific files
.vscode/
.cursor/
.cursor/skills/
.cursor/rules/

.idea/
*.swp
*.swo
*~

# OS specific files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# API Keys and Secrets
*.key
*.pem
secrets/

# Build artifacts
bin/
dist/
build/
*.log
_aether_result.txt

# Temporary files
tmp/
temp/

.vercel
.env*.local

#workspace_files
istok-agent-core.code-workspace

# ============ Keep These Files ============
!.env.example
!.gitignore
